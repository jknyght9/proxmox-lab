# =============================================================================
# Proxmox Lab - Terraform Configuration
# =============================================================================
#
# This file is auto-generated by bootstrap (lib/bootstrap.sh) from
# bootstrap.yml and cluster discovery. You can also create it manually
# by copying this file to terraform.tfvars and filling in your values.
#
# IMPORTANT: Do NOT commit terraform.tfvars to version control as it
# contains sensitive information (API tokens, passwords).
# =============================================================================

# -----------------------------------------------------------------------------
# Proxmox API (bpg/proxmox provider)
# -----------------------------------------------------------------------------
# API endpoint URL (the bootstrap script extracts this from proxmox.ip)
proxmox_endpoint = "https://192.168.1.100:8006"

# API token in format: user@realm!token=secret
# Created automatically by bootstrap via pveum commands
proxmox_api_token = "hashicorp@pam!hashicorp-token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# SSH username for bpg provider file uploads (default: root)
# proxmox_ssh_username = "root"

# Primary Proxmox node name (auto-detected by bootstrap)
proxmox_target_node = "pve01"

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
network_interface_bridge = "vmbr0"
network_gateway_address  = "192.168.1.1"

# Bootstrap DNS for initial provisioning (before Pi-hole is running).
# Typically your gateway IP. Auto-set by bootstrap from network.gateway.
bootstrap_dns = "192.168.1.1"

# -----------------------------------------------------------------------------
# DNS Configuration
# -----------------------------------------------------------------------------
# Domain suffix for all services (e.g., "mylab.lan", "home.local")
dns_postfix = "mylab.lan"

# Primary DNS server IP (first Pi-hole node, typically .4 in the subnet)
dns_primary_ipv4 = "192.168.1.4"

# DNS cluster nodes - one per Proxmox cluster node
# Auto-generated by bootstrap based on cluster discovery
dns_main_nodes = [
  {
    hostname    = "dns-01"
    target_node = "pve01"
    ip          = "192.168.1.4/24"
    gw          = "192.168.1.1"
  },
  # {
  #   hostname    = "dns-02"
  #   target_node = "pve02"
  #   ip          = "192.168.1.5/24"
  #   gw          = "192.168.1.1"
  # },
]

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Auto-detected by bootstrap. Clusters prefer shared storage; standalone
# uses local-lvm. LXC always uses block storage (not NFS/CIFS).
template_storage = "local-lvm"
vm_storage       = "local-lvm"
lxc_storage      = "local-lvm"

# -----------------------------------------------------------------------------
# Proxmox Cluster Node IPs
# -----------------------------------------------------------------------------
# Maps node names to management IPs. Auto-populated by bootstrap.
proxmox_node_ips = {
  pve01 = "192.168.1.100"
  # pve02 = "192.168.1.101"
  # pve03 = "192.168.1.102"
}

# -----------------------------------------------------------------------------
# DNS High Availability (keepalived VIP) - Optional
# -----------------------------------------------------------------------------
# enable_dns_ha_vip      = true
# dns_ha_vip_address     = "192.168.1.3/24"
# dns_ha_vrrp_router_id  = 51
# dns_ha_vrrp_password   = "dnsHA123"

# -----------------------------------------------------------------------------
# Nomad Traefik High Availability (keepalived VIP) - Optional
# -----------------------------------------------------------------------------
# nomad_traefik_ha_enabled        = true
# nomad_traefik_ha_vip            = "192.168.1.100/24"
# nomad_traefik_ha_vrrp_router_id = 53
# nomad_traefik_ha_vrrp_password  = "traefik"

# -----------------------------------------------------------------------------
# Vault Configuration
# -----------------------------------------------------------------------------
# Populated after Vault is deployed. Passwords (Pi-hole, Kasm, etc.) are
# read from Vault KV instead of being stored in this file.
# vault_address = "https://10.1.50.114:8200"
# vault_token   = "hvs.xxxxxxxxx"
