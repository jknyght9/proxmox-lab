# ============================================================================
# Proxmox Lab - Terraform Configuration
# ============================================================================
# This file is auto-populated by setup.sh when you run the initial deployment.
# You can also manually configure it by copying this file to terraform.tfvars
# and filling in your environment-specific values.
#
# IMPORTANT: Do NOT commit terraform.tfvars to version control as it contains
# sensitive information like passwords and API tokens.
# ============================================================================

# -----------------------------------------------------------------------------
# Proxmox API Authentication
# -----------------------------------------------------------------------------
# Option 1: API Token authentication (recommended)
proxmox_api_url      = "https://YOUR_PROXMOX_IP:8006/api2/json"
proxmox_api_token_id = "terraform@pam!terraform-access-token"
proxmox_api_token    = "YOUR-API-TOKEN-HERE"

# Option 2: Username/password authentication (fallback)
proxmox_api_username = "root@pam"
proxmox_api_password = "YOUR-ROOT-PASSWORD"
proxmox_target_node  = "pve01"

# -----------------------------------------------------------------------------
# Network Configuration (auto-generated by setup.sh)
# -----------------------------------------------------------------------------
# These values are configured during the interactive setup process.
# setup.sh will prompt you for your network details and update this file.
network_interface_bridge = "vmbr0"
network_gateway_address  = "YOUR.GATEWAY.IP.HERE"

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Storage for LXC containers. Common options:
#   - local-lvm (default, per-node storage)
#   - ceph, nfs-storage (shared storage for clusters)
lxc_storage = "local-lvm"

# -----------------------------------------------------------------------------
# DNS Configuration (auto-generated by setup.sh)
# -----------------------------------------------------------------------------
# DNS domain suffix for all services (e.g., "lab.local", "home.lan")
dns_postfix = "YOUR-DOMAIN.lan"

# Primary DNS IP (first DNS server deployed)
dns_primary_ipv4 = "YOUR.DNS.IP.HERE"

# Bootstrap DNS for initial provisioning (before internal DNS is ready)
# Usually your gateway DNS server. Required if external DNS (1.1.1.1) is blocked.
bootstrap_dns = "1.1.1.1"

# Pi-hole admin credentials
pihole_admin_password = "CHANGE-THIS-PASSWORD"
pihole_root_password  = "CHANGE-THIS-PASSWORD"

# DNS cluster nodes - Main cluster on external network
# Auto-generated by setup.sh based on your Proxmox cluster configuration
# IP allocation scheme (when HA is enabled):
#   .1  - Gateway (router)
#   .2  - Reserved (OPNsense or future gateway)
#   .3  - keepalived VIP (DNS HA endpoint) - optional
#   .4  - dns-01
#   .5  - dns-02
#   .6  - dns-03
#   .7  - step-ca (Certificate Authority)
#   .8+ - Other services (Nomad, Kasm, etc.)
dns_main_nodes = [
  # { hostname = "dns-01", target_node = "pve01", ip = "x.x.x.4/24", gw = "x.x.x.1" },
  # { hostname = "dns-02", target_node = "pve02", ip = "x.x.x.5/24", gw = "x.x.x.1" },
  # { hostname = "dns-03", target_node = "pve03", ip = "x.x.x.6/24", gw = "x.x.x.1" },
]

# DNS cluster nodes - Labnet SDN cluster on internal network
# Auto-generated by setup.sh if you enable the internal SDN network
dns_labnet_nodes = [
  # { hostname = "labnet-dns-01", target_node = "pve01", ip = "172.16.0.3/24", gw = "172.16.0.1" },
  # { hostname = "labnet-dns-02", target_node = "pve02", ip = "172.16.0.4/24", gw = "172.16.0.1" },
]

# Labnet DHCP Configuration (auto-generated by setup.sh)
# Enables Pi-hole to serve DHCP on the labnet SDN network
labnet_dhcp_enabled    = true
labnet_dhcp_start      = "172.16.0.100"
labnet_dhcp_end        = "172.16.0.200"
labnet_dhcp_router     = "172.16.0.1"
labnet_dhcp_lease_time = "86400"

# -----------------------------------------------------------------------------
# DNS High Availability (keepalived VIP)
# -----------------------------------------------------------------------------
# Enables automatic failover between Pi-hole nodes using VRRP.
# Clients use the VIP as their DNS server - automatic failover if primary fails.
# NOTE: Requires privileged LXC containers (less secure but necessary for VRRP).

# Main DNS cluster HA
enable_dns_ha_vip      = false           # Set to true to enable HA
dns_ha_vip_address     = ""              # e.g., "10.1.50.3/24" (VIP at .3)
dns_ha_vrrp_router_id  = 51              # Unique ID for this VRRP instance (1-255)
dns_ha_vrrp_password   = ""              # VRRP auth password (8 chars max)

# Labnet DNS cluster HA (optional, for internal SDN network)
labnet_enable_dns_ha_vip      = false
labnet_dns_ha_vip_address     = ""       # e.g., "172.16.0.3/24"
labnet_dns_ha_vrrp_router_id  = 52       # Must be different from main cluster
labnet_dns_ha_vrrp_password   = ""

# -----------------------------------------------------------------------------
# Step-CA (Certificate Authority) Configuration
# -----------------------------------------------------------------------------
step-ca_root_password  = "CHANGE-THIS-PASSWORD"
step-ca_eth0_ipv4_cidr = "YOUR.STEPCA.IP/24"

# -----------------------------------------------------------------------------
# Kasm Workspaces Configuration
# -----------------------------------------------------------------------------
kasm_version        = "1.17.0.7f020d"
kasm_admin_password = "CHANGE-THIS-PASSWORD"

# -----------------------------------------------------------------------------
# Proxmox Cluster Node IPs (auto-generated by setup.sh)
# -----------------------------------------------------------------------------
# Maps Proxmox node names to their management IPs for SSH provisioning.
# This allows Terraform to provision containers on any node in the cluster.
proxmox_node_ips = {
  # pve01 = "YOUR.NODE1.IP",
  # pve02 = "YOUR.NODE2.IP",
  # pve03 = "YOUR.NODE3.IP"
}
