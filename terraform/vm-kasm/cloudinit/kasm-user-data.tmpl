#cloud-config
# Bootstrap-only cloud-init for Kasm Workspaces VM.
# Sets up hostname, users, SSH keys, base packages, swap, and acme.sh.
# Kasm installation and certificate configuration are managed by
# Terraform null_resource provisioners so they can be reconfigured
# with `terraform apply` without recreating VMs.

hostname: ${hostname}
manage_etc_hosts: true

users:
  - name: labadmin
    groups: [sudo]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - ${ssh_authorized_keys}
  - name: root
    ssh_authorized_keys:
      - ${ssh_authorized_keys}

packages: [curl, jq, socat, ca-certificates]

runcmd:
  - |
    bash -lc '
      systemctl enable --now systemd-timesyncd || true
      systemctl restart systemd-timesyncd || true
    '
  - |
    bash -lc '
      echo "[time] waiting for NTP sync..."
      for i in {1..30}; do
        if timedatectl show -p NTPSynchronized --value 2>/dev/null | grep -qi yes; then
          timedatectl status || true
          break
        fi
        sleep 2
      done
    '
  - |
    bash -lc '
      grep -q "/swapfile" /etc/fstab || (fallocate -l 4G /swapfile
      chmod 600 /swapfile
      mkswap /swapfile
      swapon /swapfile
      echo "/swapfile none swap sw 0 0" >> /etc/fstab)
    '
  - |
    bash -lc '
      export HOME=/root; cd /root; echo "HOME=$HOME PWD=$PWD"
      command -v ~/.acme.sh/acme.sh >/dev/null || (curl -fsSL https://get.acme.sh | sh -s email=admin@${dns_postfix})
    '
